FROM python:3.11-slim

WORKDIR /app

# Install deps
COPY api/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy API source
COPY api/*.py .

# Bake in scripts and models (replaces Docker Compose volume mounts)
COPY scripts/ /scripts/
COPY models/ /models/

# Create directories for data/reports
RUN mkdir -p /data/baselines /reports

EXPOSE 8000
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]